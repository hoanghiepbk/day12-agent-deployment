# =============================================================================
# .env.local — Local environment variables
# =============================================================================
# Copy từ .env.example và điền giá trị thật
# ❌ KHÔNG commit file này lên Git! (đã có trong .gitignore)
# ✅ Chỉ commit .env.example (có giá trị mẫu, không có secrets)
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# ── LLM ──────────────────────────────────────────────────────────────────────
# Để trống → dùng Mock LLM (không cần API key, không mất tiền)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Security ─────────────────────────────────────────────────────────────────
# 🔑 Đây là API key để gọi /ask endpoint
# Test với: curl -H "X-API-Key: my-super-secret-key-2026" http://localhost:8000/ask
AGENT_API_KEY=my-super-secret-key-2026
JWT_SECRET=my-jwt-secret-2026-change-in-prod

# ── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ── Cost Guard (📌 CHECKLIST: "$10/month") ───────────────────────────────────────
MONTHLY_BUDGET_USD=10.0
COST_PER_REQUEST_USD=0.0001

# ── Redis ─────────────────────────────────────────────────────────────────────
# Khi chạy với docker compose: redis://redis:6379/0
# Khi chạy local (python app.py): để trống (dùng in-memory fallback)
REDIS_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# * = cho phép mọi domain (OK cho dev, KHÔNG dùng production)
ALLOWED_ORIGINS=*
